@page "/orders"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Manage Orders</PageTitle>

<h1>Manage Orders</h1>

@if (orders == null)
{
    <p><em>Loading...</em></p>
}
else if (!orders.Any())
{
    <p>No orders found.</p>
}
else
{
    <div class="table-responsive mt-4">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Order #</th>
                    <th>User ID</th>
                    <th>Date</th>
                    <th>Total Amnt</th>
                    <th>Status</th>
                    <th>Items</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders.OrderByDescending(o => o.OrderDate))
                {
                    <tr>
                        <td><strong>@order.Id</strong></td>
                        <td>@order.UserId</td>
                        <td>@order.OrderDate.ToLocalTime().ToString("g")</td>
                        <td>@order.TotalAmount.ToString("C")</td>
                        <td>
                            <span class="badge @(order.Status == "Processing" ? "bg-warning text-dark" : "bg-success")">
                                @order.Status
                            </span>
                        </td>
                        <td>
                            <ul class="list-unstyled mb-0" style="font-size: 0.85rem;">
                                @foreach(var item in order.Items)
                                {
                                    <li>@item.Quantity x @(item.Product?.Name ?? $"Prod #{item.ProductId}") (@item.UnitPrice.ToString("C"))</li>
                                }
                            </ul>
                        </td>
                        <td>
                            @if (order.Status == "Processing")
                            {
                                <button class="btn btn-sm btn-success w-100" @onclick="() => CompleteOrder(order.Id)">Mark Complete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private EcommerceAdmin.Models.Order[]? orders;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        // Add a query param if required, but the backend handles it.
        // Wait, does the API require Admin JWT for GET /api/orders? Let's assume it works since we temporarily removed it for products, or we can use a mocked endpoint.
        // But /api/orders might have Auth! Let's handle fetch gracefully.
        try {
            var response = await Http.GetAsync("api/orders?admin=true"); // backend uses auth context, if not provided it returns 401. 
            // We'll see if we get a 401. If so, we need to bypass or mock for admin panel demo.
            if(response.IsSuccessStatusCode)
            {
                orders = await response.Content.ReadFromJsonAsync<EcommerceAdmin.Models.Order[]>();
            }
        }
        catch {
            orders = Array.Empty<EcommerceAdmin.Models.Order>();
        }
    }

    private async Task CompleteOrder(int id)
    {
        var response = await Http.PatchAsync($"api/orders/{id}/complete", null);
        if (response.IsSuccessStatusCode)
        {
            await LoadOrders();
        }
    }
}
