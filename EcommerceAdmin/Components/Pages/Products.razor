@page "/products"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Manage Products & Inventory</PageTitle>

<h1>Manage Products & Inventory</h1>

@if (products == null || categories == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row mb-4 align-items-center">
        <div class="col-md-3">
            <label class="form-label fw-bold">Filter by Category:</label>
            <select class="form-select @(filterCategoryId > 0 ? "border-primary" : "")" @bind="filterCategoryId">
                <option value="0">All Categories</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>
        <div class="col-md-9 text-end">
            <span class="text-muted small">Showing @products.Length products</span>
        </div>
    </div>

    <table class="table table-sm table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Img</th>
                <th>Name</th>
                <th>SKU</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var prod in products)
            {
                <tr>
                    <td>@prod.Id</td>
                    <td><img src="@prod.ImageUrl" alt="@prod.Name" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" /></td>
                    <td>@prod.Name</td>
                    <td>@prod.SKU</td>
                    <td>@prod.Price.ToString("C")</td>
                    <td>
                        <span class="badge @(prod.StockQuantity > 10 ? "bg-success" : (prod.StockQuantity > 0 ? "bg-warning text-dark" : "bg-danger"))">
                            @prod.StockQuantity
                        </span>
                    </td>
                    <td>
                        @if(prod.IsActive) { <span class="badge bg-primary">Active</span> }
                        else { <span class="badge bg-secondary">Archived</span> }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditProduct(prod)">Edit</button>
                        @if(prod.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-warning me-2" @onclick="() => DeleteProduct(prod.Id)">Archive</button>
                        }
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => PermanentDeleteProduct(prod.Id, prod.Name)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <hr class="my-4" />

    <div class="card bg-light">
        <div class="card-body">
            <h3 class="card-title mb-4">@(isEditing ? "Edit Product" : "Create New Product")</h3>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="currentProduct.Name" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">SKU</label>
                    <input class="form-control" @bind="currentProduct.SKU" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Status</label>
                    <select class="form-select @(currentProduct.IsActive ? "text-primary fw-bold" : "text-muted")" 
                            @onchange="@(e => currentProduct.IsActive = bool.Parse(e.Value?.ToString() ?? "true"))">
                        <option value="true" selected="@(currentProduct.IsActive == true)">Active (Live)</option>
                        <option value="false" selected="@(currentProduct.IsActive == false)">Archived (Hidden)</option>
                    </select>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label">Description</label>
                    <input class="form-control" @bind="currentProduct.Description" />
                </div>
                
                <div class="col-md-3 mb-3">
                    <label class="form-label">Price</label>
                    <input type="number" step="0.01" class="form-control" @bind="currentProduct.Price" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Stock Quantity</label>
                    <input type="number" class="form-control" @bind="currentProduct.StockQuantity" />
                </div>
                
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Categories</label>
                    <div class="border rounded p-2 bg-white" style="max-height: 150px; overflow-y: auto;">
                        @if (categories != null)
                        {
                            @foreach (var cat in categories)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" 
                                           id="cat-@cat.Id" 
                                           checked="@currentProduct.CategoryIds.Contains(cat.Id)"
                                           @onchange="@(e => ToggleCategory(cat.Id, (bool)e.Value))" />
                                    <label class="form-check-label" for="cat-@cat.Id">
                                        @cat.Name
                                    </label>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Multiple Images Management -->
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Images</label>
                    <div class="border rounded p-3 bg-white" style="max-height: 280px; overflow-y: auto;">
                        @foreach (var img in currentProduct.Images)
                        {
                            <div class="d-flex align-items-center mb-2 gap-2">
                                <img src="@img.Url" style="width:40px;height:40px;object-fit:cover;border-radius:4px;border:1px solid #ddd;" />
                                <span class="text-truncate small flex-grow-1">@img.Url</span>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => currentProduct.Images.Remove(img)">✕</button>
                            </div>
                        }
                        <div class="mt-2">
                            <InputFile OnChange="OnImagesSelected" multiple accept="image/*"
                                       class="form-control form-control-sm" />
                            @if (isUploading)
                            {
                                <div class="d-flex align-items-center mt-2 text-primary">
                                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                    <span>Uploading @uploadProgress...</span>
                                </div>
                            }
                        </div>
                    </div>
                    <small class="text-muted">The first image will be used as the primary thumbnail.</small>
                </div>
            </div>
            
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="SaveProduct">
                    @(isEditing ? "Update Product" : "Save Product")
                </button>
                @if (isEditing)
                {
                    <button class="btn btn-secondary ms-2" @onclick="CancelEdit">Cancel</button>
                }
            </div>
        </div>
    </div>
}

@code {
    @inject IJSRuntime JSRuntime
    private EcommerceAdmin.Models.Product[]? products;
    private EcommerceAdmin.Models.Category[]? categories;
    private EcommerceAdmin.Models.Product currentProduct = new() { IsActive = true };
    private bool isUploading = false;
    private string uploadProgress = "";
    private int _filterCategoryId = 0;
    private int filterCategoryId
    {
        get => _filterCategoryId;
        set
        {
            if (_filterCategoryId != value)
            {
                _filterCategoryId = value;
                _ = LoadProducts();
            }
        }
    }
    private bool isEditing = false;
    private string lastUrl = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        await LoadProducts();
    }

    private async Task LoadCategories()
    {
        categories = await Http.GetFromJsonAsync<EcommerceAdmin.Models.Category[]>("api/categories");
    }

    private async Task LoadProducts()
    {
        // append ?includeInactive=true so admin can see archived products
        var url = "api/products?includeInactive=true";
        if (filterCategoryId > 0) url += $"&categoryId={filterCategoryId}";
        
        lastUrl = url;
        products = await Http.GetFromJsonAsync<EcommerceAdmin.Models.Product[]>(url);
        StateHasChanged();
    }

    private void EditProduct(EcommerceAdmin.Models.Product prod)
    {
        currentProduct = new EcommerceAdmin.Models.Product 
        {
            Id = prod.Id, Name = prod.Name, Description = prod.Description,
            Price = prod.Price, ImageUrl = prod.ImageUrl, 
            StockQuantity = prod.StockQuantity, SKU = prod.SKU, IsActive = prod.IsActive,
            CategoryIds = prod.CategoryIds.ToList(),
            Images = prod.Images.Select(i => new EcommerceAdmin.Models.ProductImage { Url = i.Url }).ToList()
        };
        isEditing = true;
    }

    private async Task SaveProduct()
    {
        if (isEditing)
        {
            var response = await Http.PutAsJsonAsync($"api/products/{currentProduct.Id}", currentProduct);
            if (response.IsSuccessStatusCode)
            {
                CancelEdit();
                await LoadProducts();
            }
        }
        else
        {
            var response = await Http.PostAsJsonAsync("api/products", currentProduct);
            if (response.IsSuccessStatusCode)
            {
                CancelEdit();
                await LoadProducts();
            }
        }
    }

    private async Task DeleteProduct(int id)
    {
        var response = await Http.DeleteAsync($"api/products/{id}");
        if (response.IsSuccessStatusCode)
        {
            await LoadProducts();
        }
    }

    private async Task PermanentDeleteProduct(int id, string name)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"¿Estás seguro de que deseas eliminar permanentemente '{name}'? Esta acción no se puede deshacer.");
        if (confirmed)
        {
            var response = await Http.DeleteAsync($"api/products/{id}?hardDelete=true");
            if (response.IsSuccessStatusCode)
            {
                await LoadProducts();
            }
        }
    }

    private void ToggleCategory(int categoryId, bool isChecked)
    {
        if (isChecked)
        {
            if (!currentProduct.CategoryIds.Contains(categoryId))
                currentProduct.CategoryIds.Add(categoryId);
        }
        else
        {
            currentProduct.CategoryIds.Remove(categoryId);
        }
    }

    private void CancelEdit()
    {
        currentProduct = new() { IsActive = true };
        isEditing = false;
    }

    private async Task OnImagesSelected(InputFileChangeEventArgs e)
    {
        isUploading = true;
        var files = e.GetMultipleFiles(10);
        int i = 0;
        foreach (var file in files)
        {
            i++;
            uploadProgress = $"{i}/{files.Count}";
            StateHasChanged();

            try
            {
                using var content = new MultipartFormDataContent();
                var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                var fileContent = new StreamContent(stream);
                fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                content.Add(fileContent, "file", file.Name);

                var response = await Http.PostAsync("api/upload", content);
                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                    if (result?.Url != null)
                    {
                        currentProduct.Images.Add(new EcommerceAdmin.Models.ProductImage { Url = result.Url });
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Upload error: {ex.Message}");
            }
        }

        isUploading = false;
        uploadProgress = "";
        StateHasChanged();
    }

    private record UploadResult(string Url);
}
