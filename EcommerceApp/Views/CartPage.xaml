<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EcommerceApp.Views.CartPage"
             Title="{Binding Title}">
    <Grid RowDefinitions="*, Auto">
        <CollectionView Grid.Row="0" ItemsSource="{Binding CartItems}" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10" Padding="10" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto">
                            <Image Source="{Binding Product.ImageUrl}" WidthRequest="80" HeightRequest="80" Aspect="AspectFill" Grid.RowSpan="2" Grid.Column="0" Margin="0,0,10,0"/>
                            <Label Text="{Binding Product.Name}" FontAttributes="Bold" Grid.Row="0" Grid.Column="1" />
                            <Label Text="{Binding Product.Price, StringFormat='{0:C}'}" TextColor="DarkGreen" Grid.Row="1" Grid.Column="1" />
                            <HorizontalStackLayout Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" VerticalOptions="Center" Spacing="10">
                                <Label Text="{Binding Quantity, StringFormat='Qty: {0}'}" VerticalOptions="Center"/>
                                <Button Text="Remove" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFromCartCommand}" CommandParameter="{Binding Product}" BackgroundColor="Transparent" TextColor="#FF3B30" FontSize="12" FontAttributes="Bold" Padding="5" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="1" Padding="20" BackgroundColor="{StaticResource Secondary}" StrokeThickness="1" Stroke="{StaticResource Tertiary}">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{Binding TotalAmount, StringFormat='Total: {0:C}'}" TextColor="{StaticResource TextColor}" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" Grid.Column="0" />
                <Button Text="Checkout" Command="{Binding CheckoutCommand}" BackgroundColor="{StaticResource Primary}" TextColor="White" FontAttributes="Bold" Grid.Column="1" Padding="20,0" HeightRequest="44" CornerRadius="22" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
