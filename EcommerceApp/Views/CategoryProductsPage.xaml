<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EcommerceApp.Models"
             xmlns:vm="clr-namespace:EcommerceApp.ViewModels"
             x:Class="EcommerceApp.Views.CategoryProductsPage"
             BackgroundColor="White"
             Title="{Binding CategoryName}">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadProductsCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="0,0,0,30" Spacing="10">

                <!-- Header with Cart Badge -->
                <Grid ColumnDefinitions="*, Auto" Padding="20,15,20,5">
                    <Label Text="{Binding CategoryName}" TextColor="#222" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" />
                    <Grid Grid.Column="1" WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCartCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Text="🛒" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border IsVisible="{Binding CartItemCount, Converter={StaticResource IntToBoolConverter}, FallbackValue=False}"
                                WidthRequest="18" HeightRequest="18" StrokeShape="RoundRectangle 9" BackgroundColor="Red" StrokeThickness="0"
                                HorizontalOptions="End" VerticalOptions="Start" TranslationX="5" TranslationY="-5">
                            <Label Text="{Binding CartItemCount}" TextColor="White" FontSize="10" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Grid>

                <!-- Products Grid (3 columns, all products) -->
                <FlexLayout BindableLayout.ItemsSource="{Binding Products}"
                            Wrap="Wrap"
                            JustifyContent="SpaceBetween"
                            Padding="20,5">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Product">
                            <Border Margin="0,0,0,12"
                                    Padding="0"
                                    FlexLayout.Basis="32%"
                                    HeightRequest="190"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Stroke="#F0F0F0"
                                    BackgroundColor="White">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoryProductsViewModel}}, Path=GoToDetailsCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="95, Auto" Padding="0">
                                    <!-- Image -->
                                    <Border Grid.Row="0" Margin="4" StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="#F9F9F9">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFit" />
                                    </Border>
                                    <!-- Info -->
                                    <VerticalStackLayout Grid.Row="1" Padding="8,4,8,8" Spacing="2">
                                        <Label Text="{Binding Name}" TextColor="#444444" FontSize="11" MaxLines="2" LineBreakMode="TailTruncation" HeightRequest="32" />
                                        <Label Text="{Binding Price, StringFormat='{0:C}'}" TextColor="Black" FontSize="13" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
